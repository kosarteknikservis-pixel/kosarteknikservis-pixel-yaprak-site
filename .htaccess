<IfModule mime_module>
  AddHandler application/x-httpd-php83 .php
</IfModule>
# Laragon / standart Apache: cPanel AddHandler KULLANMA — ea-php83 Laragon'da yok, .php İNDİRME olarak açılır.
# Canlı cPanel + LiteSpeed gerekiyorsa barındırıcıdaki .htaccess'e TEK satır ekleyin (buraya değil).
# ============================================
# GÜVENLİK AYARLARI - GÜÇLENDİRİLMİŞ .HTACCESS
# ============================================

# PHP limitleri: YALNIZCA Apache mod_php ile çalışır.
# php_value satırları PHP-FPM / FastCGI / bazı LiteSpeed kurulumlarında .htaccess'i BOZAR (500 / beyaz sayfa).
<IfModule mod_php.c>
    php_value upload_max_filesize 100M
    php_value post_max_size 100M
    php_value memory_limit 256M
    php_value max_execution_time 300
    php_value max_input_time 300
</IfModule>

# ============================================
# GÜVENLİK KORUMALARI
# ============================================

# Rewrite için FollowSymLinks; Content-Negotiation (MultiViews) temiz URL'leri çalabilir.
Options +FollowSymLinks -Indexes -MultiViews

# Server Signature'ı Gizle
ServerSignature Off

# PHP Ayarları (Hafifletilmiş)
<IfModule mod_php7.c>
    php_flag expose_php Off
    php_value session.cookie_httponly 1
    # php_value session.cookie_secure 1  # HTTPS olmadan çalışmaz, yorum satırına alındı
    php_value session.use_only_cookies 1
</IfModule>

# Hassas Dosyaları Koru - Kaldırıldı (403 hatası veriyordu)
# <FilesMatch "\.(htaccess|htpasswd|ini|log|sh|sql|bak|backup|old|orig|save|swp|tmp)$">
#     Order allow,deny
#     Deny from all
# </FilesMatch>

# Config Dosyalarını Koru - Kaldırıldı (403 hatası veriyordu)
# <FilesMatch "^(config|config\.php|config\.inc|db\.php|database\.php|settings\.php)$">
#     Order allow,deny
#     Deny from all
# </FilesMatch>

# Error Log Dosyalarını Koru - Kaldırıldı (403 hatası veriyordu)
# <FilesMatch "^(error_log|error\.log|\.log)$">
#     Order allow,deny
#     Deny from all
# </FilesMatch>

# ============================================
# XSS ve SQL Injection Koruması (Hafifletilmiş)
# ============================================

# XSS ve SQL Injection Koruması - Kaldırıldı (403 hatası veriyordu)
# <IfModule mod_rewrite.c>
#     # Sadece açık SQL injection denemelerini engelle
#     RewriteCond %{QUERY_STRING} (union|select|insert|drop|update|delete|truncate|exec|execute).*(from|into|table|database) [NC,OR]
#     RewriteCond %{QUERY_STRING} (\.\./|\.\.\\|boot\.ini|etc/passwd) [NC]
#     RewriteRule .* - [F,L]
# </IfModule>

# ============================================
# DOSYA ERİŞİM KORUMALARI
# ============================================

# Statik dosyalar için 404 döndür (güvenlik) - Yorum satırına alındı
# Bu kural CSS ve JS dosyalarının yüklenmesini engelleyebilir
# RewriteCond %{REQUEST_FILENAME} !-f
# RewriteRule \.(css|js|jpg|jpeg|png|gif|ico|swf|bmp|woff|woff2|ttf|eot|svg)$ - [nocase,redirect=404,last]

# ============================================
# URL REWRITE KURALLARI
# ============================================

# PayTR yasal sayfalar — /teslimat-kosullari → .php (LiteSpeed uyumlu)
RedirectMatch 301 (?i)^/teslimat-kosullari/?$ /teslimat-kosullari.php
RedirectMatch 301 (?i)^/satis-politikasi/?$ /satis-politikasi.php
RedirectMatch 301 (?i)^/iptal-iade/?$ /iptal-iade.php
RedirectMatch 301 (?i)^/gizlilik/?$ /gizlilik.php

<IfModule mod_rewrite.c>
# RewriteBase bazı kurulumlarda (ör. sanal host kökü = nir) yanlış olunca kurallar çalışmaz.
# Boş bırakınca Apache alt klasörü kendisi çözer; sorun yaşarsanız tek satır deneyin: RewriteBase /nir/ veya RewriteBase /
RewriteEngine On
RewriteBase /

# Yasal sayfalar — klasör/index.php (LiteSpeed uyumlu)
RewriteRule ^teslimat-kosullari/?$ teslimat-kosullari/index.php [NC,L]
RewriteRule ^satis-politikasi/?$ satis-politikasi/index.php [NC,L]
RewriteRule ^iptal-iade/?$ iptal-iade/index.php [NC,L]
RewriteRule ^gizlilik/?$ gizlilik/index.php [NC,L]

RewriteRule ^robots\.txt$ robots.php [NC,L]
RewriteRule ^sitemap\.xml$ sitemap.php [NC,L]

RewriteRule ^siparis-onay$ siparis-onay.php [NC,L]
RewriteRule ^sozlesme$ sozlesme.php [NC,L]
RewriteRule ^guvenli-odeme$ guvenli-odeme.php [NC,L]
RewriteRule ^sayfa/([0-9a-zA-Z-_]+)$ sayfa.php?slug=$1 [NC,L,QSA]
RewriteRule ^urun/([0-9a-zA-Z-_]+)$ index.php [NC,L]

# Dinamik formlar: /nir/destek-talebi → form-goruntule.php?slug=destek-talebi
RewriteCond %{REQUEST_URI} !^/(teslimat-kosullari|satis-politikasi|iptal-iade|gizlilik|sozlesme|guvenli-odeme|siparis-onay)(\.php)?/?$ [NC]
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^([A-Za-z0-9_-]+)/?$ form-goruntule.php?slug=$1 [L,QSA]
</IfModule>

# ============================================
# SSL YÖNLENDİRME (İsteğe Bağlı - Yorumdan Çıkar)
# ============================================

# SSL Zorunlu Yapmak İçin:
# SSL Zorunlu Yapmak İçin:
# RewriteCond %{HTTPS} off
# RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# ============================================
# ERROR PAGES
# ============================================

# Alt klasör: /nir/404.php — site köküne taşıyınca /404.php yapın
ErrorDocument 404 /nir/404.php
# ErrorDocument 403 /403.php
# ErrorDocument 500 /500.php

# ============================================
# MIME TYPES
# ============================================

<IfModule mod_mime.c>
    AddType application/javascript js
    AddType text/css css
    AddType image/svg+xml svg svgz
    AddType application/json json
    AddType application/x-font-woff woff
    AddType application/x-font-woff2 woff2
    AddType application/vnd.ms-fontobject eot
    AddType font/truetype ttf
    AddType font/opentype otf
</IfModule>

# ============================================
# CACHE CONTROL (Performans)
# ============================================

<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/jpg "access plus 1 year"
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/gif "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
    ExpiresByType text/css "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
    ExpiresByType application/pdf "access plus 1 month"
    ExpiresByType text/x-javascript "access plus 1 month"
    ExpiresByType application/x-shockwave-flash "access plus 1 month"
    ExpiresByType image/x-icon "access plus 1 year"
    ExpiresDefault "access plus 2 days"
</IfModule>

# ============================================
# GZIP COMPRESSION (Performans)
# ============================================

<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript application/json application/xml
    AddOutputFilterByType DEFLATE image/svg+xml
</IfModule>

# ============================================
# HEADER GÜVENLİK AYARLARI
# ============================================

<IfModule mod_headers.c>
    # XSS Protection
    Header set X-XSS-Protection "1; mode=block"
    
    # Clickjacking Protection
    Header always set X-Frame-Options "SAMEORIGIN"
    
    # MIME Type Sniffing Protection
    Header set X-Content-Type-Options "nosniff"
    
    # Referrer Policy
    Header set Referrer-Policy "strict-origin-when-cross-origin"
    
    # Content Security Policy (CSP) - İsteğe Bağlı
    # Header set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline';"
    
    # Remove Server Information
    Header unset Server
    Header unset X-Powered-By
</IfModule>

# ============================================
# PHP HANDLER (cPanel için)
# ============================================

# php -- BEGIN cPanel-generated handler, do not edit
# Set the "ea-php72" package as the default "PHP" programming language.
<IfModule mime_module>
    # AddHandler application/x-httpd-ea-php72___lsphp .php .php7 .phtml
</IfModule>
# php -- END cPanel-generated handler, do not edit

# ============================================
# BOT KORUMASI (Hafifletilmiş - Yorum Satırına Alındı)
# ============================================

# Kötü niyetli botları engelle (Çok katı, yorum satırına alındı)
# <IfModule mod_rewrite.c>
#     RewriteCond %{HTTP_USER_AGENT} ^$ [OR]
#     RewriteCond %{HTTP_USER_AGENT} ^(-|\.|') [OR]
#     RewriteCond %{HTTP_USER_AGENT} ^(.*)(libwww-perl|wget|python|nikto|curl|scan|java|winhttp|clshttp|loader)(.*) [NC,OR]
#     RewriteCond %{HTTP_USER_AGENT} ^(.*)(;|<|>|'|"|\)|\(|%0A|%0D|%27|%3C|%3E|%00)(.*) [NC]
#     RewriteRule .* - [F,L]
# </IfModule>

# ============================================
# HOTLINK PROTECTION (İsteğe Bağlı)
# ============================================

# Resimlerin başka sitelerden kullanılmasını engelle
# RewriteCond %{HTTP_REFERER} !^$
# RewriteCond %{HTTP_REFERER} !^http(s)?://(www\.)?yourdomain.com [NC]
# RewriteRule \.(jpg|jpeg|png|gif|webp)$ - [NC,F,L]
